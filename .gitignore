# Android / Gradle project .gitignore
# ---------------------------------------------------
# Gradle files/folders
.gradle/
build/
# Local configuration (contains SDK paths, should not be committed)
local.properties
# Android Studio project files
.idea/
*.iml
# Misc editor files
.vscode/
# OS generated files
.DS_Store
Thumbs.db
# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Build outputs (already covered by build/)
#dist/
out/
# Temporary files
*.tmp
*.temp
# Keystore files (if any)
*.jks
*.keystore
# Android specific generated folders
**/build/**
**/captures/**
**/outputs/**
# End of .gitignore
